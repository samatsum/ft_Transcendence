# Optional: pin the Emscripten image used by Docker Compose.
EMSDK_IMAGE=emscripten/emsdk:latest

# Optional: change the host port used by the development web server.
WEB_PORT=8000

# Optional on Linux/WSL: uncomment and set these to your real `id -u` / `id -g`
# if you want generated files to be owned by your user. By default Compose runs
# as root to avoid first-run bind-mount permission errors on fresh clones.
# HOST_UID=1000
# HOST_GID=1000
