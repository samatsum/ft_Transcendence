# Copy to .env if Docker-created files should match your host user.
# On Linux/WSL, use: HOST_UID=$(id -u) HOST_GID=$(id -g) docker compose run --rm engine-build make web
HOST_UID=1000
HOST_GID=1000

# Pin this if you want reproducible Emscripten versions instead of latest.
EMSDK_IMAGE=emscripten/emsdk:latest
