# Optional: pin the Emscripten image used by Docker Compose.
EMSDK_IMAGE=emscripten/emsdk:latest

# Optional: change the host port used by the development web server.
WEB_PORT=8000

# Optional on Linux/WSL: uncomment and set these to your real `id -u` / `id -g`
# if you want generated files to be owned by your user. By default Compose runs
# as root to avoid first-run bind-mount permission errors on fresh clones.
# HOST_UID=1000
# HOST_GID=1000

# --- Web application (W-01 scaffold) ---------------------------------------
# Backend (Fastify) listen port. The frontend dev server proxies /api here.
BACKEND_PORT=3000

# Frontend (Vite) dev server port.
FRONTEND_PORT=5173

# --- Added by later issues -------------------------------------------------
# W-03 (Prisma/SQLite): DATABASE_URL="file:./data/dev.db"
# W-04 (auth):          SESSION_SECRET=change-me-to-a-long-random-string
# W-05 (origin check):  ALLOWED_ORIGIN=https://localhost
